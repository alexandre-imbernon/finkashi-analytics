{
    "name": "finkashi/analytics",
    "description": "Outil de mesure d'audience web auto-heberge, sans cookie, respectueux de la vie privee.",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.3",
        "ext-pdo": "*",
        "geoip2/geoip2": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Finkashi\\Analytics\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Finkashi\\Analytics\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "migrate": "php scripts/migrate.php"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
