# Modele de fichier d'environnement.
# Copiez ce fichier en ".env" et remplissez les valeurs.
# Le fichier .env ne doit JAMAIS etre versionne (il est dans .gitignore).
#
# Pour generer des secrets robustes :
#   docker compose exec php php -r "echo bin2hex(random_bytes(32));"

APP_API_KEY=remplacer-par-votre-cle
APP_SEL_SECRET=remplacer-par-votre-secret
APP_DOMAINE=finkashi.fr
